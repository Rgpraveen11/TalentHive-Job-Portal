# ── Server ────────────────────────────────────────
PORT=5000
NODE_ENV=development

# ── MongoDB ───────────────────────────────────────
# Local:
MONGO_URI=mongodb://localhost:27017/jobportal
# Atlas (replace with your connection string):
# MONGO_URI=mongodb+srv://<username>:<password>@cluster0.mongodb.net/jobportal?retryWrites=true&w=majority

# ── JWT ───────────────────────────────────────────
JWT_SECRET=replace_this_with_a_long_random_secret_string_min_32_chars
JWT_EXPIRE=30d

# ── Cloudinary (file uploads) ─────────────────────
# Create a free account at https://cloudinary.com
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# ── LinkedIn OAuth 2.0 ────────────────────────────
# Create an app at https://developer.linkedin.com
LINKEDIN_CLIENT_ID=your_linkedin_client_id
LINKEDIN_CLIENT_SECRET=your_linkedin_client_secret
LINKEDIN_CALLBACK_URL=http://localhost:5000/api/auth/linkedin/callback

# ── Frontend URL (CORS + OAuth redirect) ─────────
CLIENT_URL=http://localhost:3000

# ── Email / Nodemailer ────────────────────────────
# For Gmail: enable 2FA and generate an App Password
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your_email@gmail.com
EMAIL_PASS=your_gmail_app_password
EMAIL_FROM=TalentHive <noreply@talenthive.com>